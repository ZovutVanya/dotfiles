background-opacity = 0.85
background-blur = 1
background = black

notify-on-command-finish = unfocused
notify-on-command-finish-action = bell,notify
notify-on-command-finish-after = 30s

font-family = CommitMonoG1
font-size = 18

cursor-style = block
shell-integration-features = no-cursor, ssh-env, ssh-terminfo, sudo, title

macos-titlebar-style = tabs
macos-icon = official

confirm-close-surface=false

window-height = 21
window-width = 75

window-position-x = 0
window-position-y = 0
window-save-state = always

keybind = unconsumed:ctrl+k=goto_split:top
keybind = unconsumed:ctrl+j=goto_split:bottom
keybind = unconsumed:ctrl+h=goto_split:left
keybind = unconsumed:ctrl+l=goto_split:right

custom-shader = shaders/cursor_smear_fade.glsl

